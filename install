# ─── Spinner / Loading Animation ─────────────────────────────────────────────
spinner_pid=""

start_spinner() {
  local label="${1:-Installing...}"
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local colors=("\033[96m" "\033[94m" "\033[95m" "\033[92m")
  local i=0 c=0
  (
    tput civis 2>/dev/null || true
    while true; do
      local frame="${frames[$((i % ${#frames[@]}))]}"
      local col="${colors[$((c % ${#colors[@]}))]}"
      printf "\r  ${col}${frame}\033[0m  \033[97m%-55s\033[0m" "$label"
      i=$((i + 1))
      [[ $((i % 10)) -eq 0 ]] && c=$((c + 1))
      sleep 0.08
    done
  ) &
  spinner_pid=$!
  disown $spinner_pid 2>/dev/null || true
}

stop_spinner() {
  local status="${1:-0}"
  if [[ -n "$spinner_pid" ]]; then
    kill "$spinner_pid" 2>/dev/null || true
    wait "$spinner_pid" 2>/dev/null || true
    spinner_pid=""
  fi
  tput cnorm 2>/dev/null || true
  if [[ "$status" -eq 0 ]]; then
    printf "\r  \033[92m✔\033[0m  %-55s\n" "${2:-Done}"
  else
    printf "\r  \033[91m✖\033[0m  %-55s\n" "${2:-Failed}"
  fi
}

# Wrapper: jalankan perintah dengan spinner, sembunyikan semua output
run_quiet() {
  local label="$1"; shift
  start_spinner "$label"
  "$@" > /dev/null 2>&1
  local rc=$?
  stop_spinner $rc "$label"
  return $rc
}

# ─── Wrappers untuk package manager ──────────────────────────────────────────
apt_install() {
  local label="Menginstall: $*"
  start_spinner "$label"
  DEBIAN_FRONTEND=noninteractive apt-get install -y "$@" > /dev/null 2>&1
  local rc=$?
  stop_spinner $rc "$label"
  return $rc
}

apt_update() {
  run_quiet "Memperbarui daftar paket..." apt-get update -y
}

apt_upgrade() {
  run_quiet "Upgrade paket sistem..." DEBIAN_FRONTEND=noninteractive apt-get upgrade -y
}

apt_dist_upgrade() {
  run_quiet "Dist-upgrade paket sistem..." DEBIAN_FRONTEND=noninteractive apt-get dist-upgrade -y
}

gem_install() {
  run_quiet "Menginstall gem: $*" gem install "$@"
}

npm_install() {
  run_quiet "Menginstall npm: $*" npm install "$@"
}

pip_install() {
  run_quiet "Menginstall pip: $*" pip3 install "$@"
}

wget_quiet() {
  local label="Mengunduh: $1"
  local args=("${@:2}")
  start_spinner "$label"
  wget -q "${args[@]}" > /dev/null 2>&1
  local rc=$?
  stop_spinner $rc "$label"
  return $rc
}

curl_quiet() {
  run_quiet "Mengunduh dengan curl..." curl -s "$@"
}

# ─── Utility functions ────────────────────────────────────────────────────────
function print_ok() {
echo -e "${OK} ${BLUE} $1 ${FONT}"
}
function print_install() {
echo ""
echo -e "\033[96;1m  ┌──────────────────────────────────────────────────┐\033[0m"
echo -e "\033[96;1m  │\033[0m  \033[93;1m⚙  $1\033[0m"
echo -e "\033[96;1m  └──────────────────────────────────────────────────┘\033[0m"
echo ""
sleep 0.5
}
function print_error() {
echo -e "${ERROR} ${REDBG} $1 ${FONT}"
}
function print_success() {
if [[ 0 -eq $? ]]; then
echo ""
echo -e "\033[92;1m  ✔  $1 berhasil dipasang\033[0m"
echo ""
sleep 1
fi
}

