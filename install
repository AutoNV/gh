# ─── Progress Bar Animation ───────────────────────────────────────────────────
PROGRESS=0
TOTAL_STEPS=20

show_progress() {
  local step="$1"
  local label="$2"
  local pct=$(( step * 100 / TOTAL_STEPS ))
  local filled=$(( pct / 2 ))
  local empty=$(( 50 - filled ))
  local bar=""
  for ((i=0; i<filled; i++)); do bar+="█"; done
  for ((i=0; i<empty; i++)); do  bar+="░"; done
  clear
  echo ""
  echo -e "\033[96;1m  ╔══════════════════════════════════════════════════╗\033[0m"
  echo -e "\033[96;1m  ║           ⚡  NEXUSDEV  INSTALLER                ║\033[0m"
  echo -e "\033[96;1m  ╚══════════════════════════════════════════════════╝\033[0m"
  echo ""
  if   [[ $pct -lt 30 ]]; then COLOR="\033[91;1m"
  elif [[ $pct -lt 60 ]]; then COLOR="\033[93;1m"
  elif [[ $pct -lt 90 ]]; then COLOR="\033[96;1m"
  else COLOR="\033[92;1m"; fi
  echo -e "  ${COLOR}[${bar}] ${pct}%\033[0m"
  echo ""
  echo -e "  \033[97m⟳  ${label}\033[0m"
  echo ""
  [[ $pct -eq 100 ]] && echo -e "  \033[92;1m✔  INSTALASI SELESAI!\033[0m" && echo ""
}

# ─── Install API Function ─────────────────────────────────────────────────────
function install_api_service(){
mkdir -p /etc/xray/api
if ! command -v node &>/dev/null; then
run_quiet "Menginstall Node.js v18..." bash -c "curl -fsSL https://deb.nodesource.com/setup_18.x | bash - && apt-get install -y nodejs"
fi
if [[ ! -f /etc/ssh/api_auth.key ]] || [[ -z "$(cat /etc/ssh/api_auth.key 2>/dev/null)" ]]; then
NEW_KEY=$(tr -dc 'a-z0-9' < /dev/urandom | head -c 12)
echo "$NEW_KEY" > /etc/ssh/api_auth.key
chmod 600 /etc/ssh/api_auth.key
fi
run_quiet "Mengunduh api.js NEXUSDEV..." wget -q -O /etc/xray/api/api.js \
  "https://raw.githubusercontent.com/AutoNV/gh/main/api/api.js"
cat > /etc/systemd/system/xray-api.service <<'EOF'
[Unit]
Description=NEXUSDEV REST API Service
After=network.target
[Service]
Type=simple
User=root
WorkingDirectory=/etc/xray/api
ExecStart=/usr/bin/node /etc/xray/api/api.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
[Install]
WantedBy=multi-user.target
EOF
NGINX_CONF="/etc/nginx/conf.d/xray.conf"
if [[ -f "$NGINX_CONF" ]] && ! grep -q "location /api/" "$NGINX_CONF" 2>/dev/null; then
python3 - <<'PYEOF'
with open("/etc/nginx/conf.d/xray.conf", "r") as f:
    content = f.read()
location_block = """
    # ── REST API proxy (NEXUSDEV) ──────────────────────────────
    location /api/ {
        proxy_pass         http://127.0.0.1:7979;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        proxy_connect_timeout 10s;
        add_header Access-Control-Allow-Origin  "*" always;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type" always;
        if ($request_method = OPTIONS) { return 204; }
    }
    # ────────────────────────────────────────────────────────────
"""
last_brace = content.rfind("}")
if last_brace != -1:
    new_content = content[:last_brace] + location_block + "\n" + content[last_brace:]
    with open("/etc/nginx/conf.d/xray.conf", "w") as f:
        f.write(new_content)
PYEOF
fi
iptables -I INPUT -p tcp --dport 7979 -j ACCEPT 2>/dev/null || true
run_quiet "Daemon reload..." systemctl daemon-reload
run_quiet "Enable xray-api..." systemctl enable xray-api.service
run_quiet "Stop xray-api..." systemctl stop xray-api.service
run_quiet "Start xray-api..." systemctl start xray-api.service
run_quiet "Reload nginx..." bash -c "nginx -t && systemctl reload nginx"
}

