echo -e "\033[96;1m  ║           ⚡  NEXUSDEV  INSTALLER                ║\033[0m"
echo -e "\033[96;1m  ╚══════════════════════════════════════════════════╝\033[0m"
echo ""
echo -e "  \033[92;1m[██████████████████████████████████████████████████] 100%\033[0m"
echo ""
